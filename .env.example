# ─────────────────────────────────────────────────────────────────────────
# AgOS — шаблон переменных окружения
#
# Локальная разработка: скопируй в `.env` и заполни значениями staging-проекта
# (НЕ прода), чтобы локальные тесты не трогали живые данные.
#
# Деплой (Vercel): значения берутся из Vercel → Settings → Environment Variables,
# scoped по окружению:
#   Production            → прод-проект Supabase
#   Preview + Development → staging-проект Supabase
#
# ВАЖНО: VITE_* переменные впекаются в браузерный бандл на этапе сборки.
# Никогда не клади секреты (service-role и т.п.) в VITE_* переменную.
# ─────────────────────────────────────────────────────────────────────────

# --- Supabase (клиент во фронте) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Новый "publishable" ключ Supabase (опционально, если используется вместо anon):
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- AI Gateway (Railway) ---
VITE_AI_GATEWAY_URL=

# --- Consulting engine (Python-сервис) ---
VITE_CONSULTING_ENGINE_URL=

# --- Аналитика (PostHog) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# --- Только сервер / локальные скрипты и миграции — НЕ попадает в браузер ---
# Держать в локальном .env (gitignored). Никогда не префиксовать VITE_.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Сид админ-аккаунта (scripts/seed_admin.mjs). НЕ префиксовать VITE_. ---
# Пароль не попадает в бандл: его вводит человек на /admin/login.
# Задайте надёжный пароль ЛОКАЛЬНО (в gitignored .env). НЕ коммить реальные значения —
# сид без ADMIN_PASSWORD упадёт с ошибкой (дефолтного пароля нет, по соображениям безопасности).
ADMIN_EMAIL=admin@agos.local
ADMIN_PASSWORD=
